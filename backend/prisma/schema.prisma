datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String            @id
  name                 String
  email                String            @unique
  role                 String            // 'manager' or 'member'
  avatarUrl            String?
  isActive             Boolean           @default(true)
  updatedAt            DateTime          @updatedAt @default(now())
  createdAt            DateTime          @default(now())
  
  ownedProjects        Project[]
  projectMembers       ProjectMember[]
  assignedTasks        Task[]
  notifications        Notification[]    @relation("userNotifications")
  createdNotifications Notification[]    @relation("creatorNotifications")
  auditLogs            AuditLog[]
}

model ForgotPasswordHistory {
  id              Int       @id @default(autoincrement())
  userId          String?
  email           String
  otpHash         String
  expiresAt       DateTime
  verified        Boolean   @default(false)
  resetCompleted  Boolean   @default(false)
  attemptCount    Int       @default(0)
  lastAttempt     DateTime?
  lockedUntil     DateTime?
  requestedAt     DateTime  @default(now())

  @@index([email])
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  
  members     ProjectMember[]
  tasks       Task[]
}

model ProjectMember {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Task {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    String   // 'LOW', 'MEDIUM', 'HIGH'
  status      String   // 'TODO', 'IN_PROGRESS', 'DONE'
  assignedTo  String?
  assignee    User?    @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  dueDate     DateTime?
  updatedAt   DateTime @updatedAt @default(now())
  createdAt   DateTime @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("userNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       String   // 'TASK_ASSIGNED', 'TASK_UPDATED', 'PROJECT_CREATED', 'SYSTEM'
  readStatus Boolean  @default(false)
  createdBy  String?
  creator    User?    @relation("creatorNotifications", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  ip        String?
  userAgent String?
  oldData   String?
  newData   String?
  createdAt DateTime @default(now())
}
